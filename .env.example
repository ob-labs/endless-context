# Endless Context minimal configuration for Bub + SeekDB (OceanBase-compatible)
# Copy this file to .env and fill in your provider credentials.

# Tape store
# This example targets Docker Compose, where the app reaches SeekDB at `seekdb:2881`.
# For bare-metal or the single-container image, change the host to the actual reachable endpoint.
BUB_TAPESTORE_SQLALCHEMY_URL=mysql+oceanbase://root@seekdb:2881/bub

# Bub runtime
BUB_MODEL=openai:qwen-plus
BUB_MAX_TOKENS=2048
BUB_GRADIO_HOST=0.0.0.0
BUB_GRADIO_PORT=7860
BUB_WORKSPACE_PATH=/app
BUB_MCP_CONFIG_PATH=/app/.bub/mcp.json

# LLM credentials
BUB_API_KEY=your_api_key_here
BUB_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
